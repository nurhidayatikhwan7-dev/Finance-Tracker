# ========================================
# MySQL Backend Configuration
# ========================================

# Server Port
PORT=3001

# MySQL Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=finance_tracker

# ========================================
# INSTRUCTIONS:
# ========================================
# 1. Copy this file to .env in your backend folder
# 2. Replace 'your_mysql_password_here' with your actual MySQL password
# 3. If using XAMPP with no password, leave DB_PASSWORD empty: DB_PASSWORD=
# 4. Make sure MySQL server is running before starting the backend

# ========================================
# EXAMPLE for XAMPP (no password):
# ========================================
# PORT=3001
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=finance_tracker
